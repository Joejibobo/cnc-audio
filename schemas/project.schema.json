{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Joejibobo/cnc-audio/schemas/project.schema.json",
  "title": "CNC Audio Project",
  "description": "A CNC Audio project file (.cnc) — contains assets, generation parameters, seed, and the rendered timeline.",
  "type": "object",
  "required": ["version", "project", "assets", "parameters", "seed"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version (semver)",
      "example": "1.0.0"
    },
    "project": {
      "type": "object",
      "required": ["name", "created_at"],
      "properties": {
        "name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "array",
      "description": "All audio clips registered in this project",
      "items": { "$ref": "#/definitions/Asset" }
    },
    "parameters": { "$ref": "#/definitions/Parameters" },
    "seed": {
      "type": "string",
      "description": "Seed string for deterministic random generation. Same seed + same assets + same parameters = same timeline."
    },
    "timeline": {
      "$ref": "#/definitions/Timeline",
      "description": "The generated timeline. Absent if no generation has been run yet."
    },
    "export": { "$ref": "#/definitions/ExportSettings" }
  },
  "definitions": {
    "Asset": {
      "type": "object",
      "required": ["id", "name", "path", "hash", "duration_seconds"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this asset within the project"
        },
        "name": { "type": "string", "description": "Display name" },
        "path": {
          "type": "string",
          "description": "Path to the audio file, relative to the project file"
        },
        "hash": {
          "type": "string",
          "description": "SHA-256 hash of the file — used to detect modified or missing files"
        },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "sample_rate": { "type": "integer" },
        "channels": { "type": "integer", "minimum": 1, "maximum": 2 },
        "format": { "type": "string", "description": "e.g. wav, mp3, flac" },
        "weight": {
          "type": "number",
          "minimum": 0,
          "default": 1.0,
          "description": "Selection probability weight relative to other clips. Higher = selected more often."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "User-defined tags for grouping or filtering clips"
        },
        "analysis": { "$ref": "#/definitions/AnalysisResult" }
      }
    },
    "AnalysisResult": {
      "type": "object",
      "description": "Optional analysis results. Only present if analysis has been run on this asset.",
      "additionalProperties": false,
      "properties": {
        "bpm": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "description": "Detected beats per minute" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "key": {
          "type": "object",
          "properties": {
            "value": { "type": "string", "description": "e.g. 'C major', 'A minor'" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        },
        "lufs": {
          "type": "number",
          "description": "Integrated loudness in LUFS (measured by FFmpeg loudnorm)"
        },
        "energy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Normalized energy level: 0 = quiet/sparse, 1 = loud/intense"
        }
      }
    },
    "Parameters": {
      "type": "object",
      "required": ["target_duration_seconds", "clip_duration"],
      "additionalProperties": false,
      "properties": {
        "target_duration_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Desired total output track length in seconds (hard constraint)"
        },
        "clip_duration": {
          "type": "object",
          "required": ["min_seconds", "max_seconds"],
          "additionalProperties": false,
          "properties": {
            "min_seconds": {
              "type": "number",
              "minimum": 0,
              "description": "Minimum duration any clip may contribute (hard constraint)"
            },
            "max_seconds": {
              "type": "number",
              "minimum": 0,
              "description": "Maximum duration any clip may contribute. Clips longer than this will be trimmed."
            }
          }
        },
        "repetition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_per_clip": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum number of times any single clip may appear in the output (hard constraint)"
            },
            "min_gap_clips": {
              "type": "integer",
              "minimum": 0,
              "description": "Minimum number of *different* clips that must appear between reuses of the same clip (soft preference)"
            },
            "allow_consecutive": {
              "type": "boolean",
              "default": false,
              "description": "Whether the same clip is allowed to play back-to-back"
            }
          }
        },
        "crossfade": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "min_seconds": { "type": "number", "minimum": 0, "default": 0.1 },
            "max_seconds": { "type": "number", "minimum": 0, "default": 2.0 },
            "probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.8,
              "description": "Probability that any given transition uses a crossfade rather than a hard cut"
            }
          }
        },
        "silence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "probability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Probability a silence gap is inserted between any two clips"
            },
            "min_seconds": { "type": "number", "minimum": 0 },
            "max_seconds": { "type": "number", "minimum": 0 }
          }
        },
        "gain": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "normalize": {
              "type": "boolean",
              "default": true,
              "description": "Normalize clips toward a target loudness before applying random variation. Non-destructive — stored as gain_db on each timeline event."
            },
            "target_lufs": {
              "type": "number",
              "default": -18,
              "description": "Target loudness for per-clip normalization (LUFS)"
            },
            "max_gain_db": {
              "type": "number",
              "default": 12,
              "description": "Maximum gain boost allowed during normalization (dB). Clips that need more than this are left at this ceiling."
            },
            "random_variation_db": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "Maximum random per-clip gain variation (±dB). 0 = no variation."
            }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "distribution": {
              "type": "string",
              "enum": ["uniform", "weighted", "sequential"],
              "default": "weighted",
              "description": "uniform: equal chance for all clips. weighted: uses per-asset weight. sequential: iterates clips in order."
            },
            "chaos": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.5,
              "description": "High-level chaos control. 0 = most constrained/predictable. 1 = most random/unpredictable. Scales internal soft-preference weights."
            }
          }
        },
        "duration_rule": {
          "type": "string",
          "enum": ["trim_last", "fade_last", "pad_silence"],
          "default": "fade_last",
          "description": "How the final clip is handled to hit the exact target duration. trim_last: hard cut. fade_last: fade out over the final 2s. pad_silence: append silence."
        }
      }
    },
    "Timeline": {
      "type": "object",
      "required": ["events", "total_duration_seconds"],
      "additionalProperties": false,
      "properties": {
        "total_duration_seconds": {
          "type": "number",
          "description": "Actual total duration of this timeline (should match target_duration_seconds)"
        },
        "events": {
          "type": "array",
          "description": "Ordered list of timeline events (clips and silences)",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/ClipEvent" },
              { "$ref": "#/definitions/SilenceEvent" }
            ]
          }
        }
      }
    },
    "ClipEvent": {
      "type": "object",
      "required": ["type", "asset_id", "position_seconds", "source_start_seconds", "source_end_seconds"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "clip" },
        "asset_id": {
          "type": "string",
          "description": "References an asset by its id field"
        },
        "position_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Start position of this event in the output track"
        },
        "source_start_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Start offset within the source audio file"
        },
        "source_end_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "End offset within the source audio file"
        },
        "gain_db": {
          "type": "number",
          "default": 0,
          "description": "Non-destructive gain adjustment for this clip instance (dB). Applied at render time."
        },
        "fade_in_seconds": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Fade-in duration at the start of this clip instance"
        },
        "fade_out_seconds": {
          "type": "number",
          "minimum": 0,
          "default": 0,
          "description": "Fade-out duration at the end of this clip instance"
        },
        "locked": {
          "type": "boolean",
          "default": false,
          "description": "If true, this event is preserved during reroll operations"
        }
      }
    },
    "SilenceEvent": {
      "type": "object",
      "required": ["type", "position_seconds", "duration_seconds"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "silence" },
        "position_seconds": { "type": "number", "minimum": 0 },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "locked": { "type": "boolean", "default": false }
      }
    },
    "ExportSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": ["wav", "mp3", "flac", "aac"],
          "default": "wav"
        },
        "sample_rate": {
          "type": "integer",
          "default": 44100
        },
        "bit_depth": {
          "type": "integer",
          "enum": [16, 24, 32],
          "default": 24
        },
        "normalize_output": {
          "type": "boolean",
          "default": true,
          "description": "Apply loudnorm pass to the final rendered track"
        },
        "target_output_lufs": {
          "type": "number",
          "default": -14,
          "description": "Target integrated loudness for the output track (LUFS)"
        },
        "true_peak_limit_dbtp": {
          "type": "number",
          "default": -1.0,
          "description": "True-peak ceiling for the output track (dBTP). Prevents inter-sample clipping."
        }
      }
    }
  }
}
