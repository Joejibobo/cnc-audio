{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Joejibobo/cnc-audio/schemas/project.schema.json",
  "title": "CNC Audio Project",
  "description": "Portable CNC Audio project format, schema version 1.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "assets", "parameters", "seed", "export"],
  "properties": {
    "version": { "const": "1.0.0" },
    "project": { "$ref": "#/definitions/ProjectMetadata" },
    "assets": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "#/definitions/Asset" }
    },
    "parameters": { "$ref": "#/definitions/Parameters" },
    "seed": { "type": "string", "minLength": 1, "maxLength": 500 },
    "timeline": { "$ref": "#/definitions/Timeline" },
    "export": { "$ref": "#/definitions/ExportSettings" }
  },
  "definitions": {
    "ProjectMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "created_at"],
      "properties": {
        "name": { "type": "string", "maxLength": 200 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "description": { "type": "string", "maxLength": 2000 },
        "song_assets": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/definitions/Asset" }
        },
        "sound_assets": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/definitions/Asset" }
        },
        "song_parameters": { "$ref": "#/definitions/Parameters" },
        "sound_parameters": { "$ref": "#/definitions/Parameters" },
        "render_settings": { "$ref": "#/definitions/RenderSettings" }
      }
    },
    "Asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "hash", "duration_seconds", "weight"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,127}$"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "path": {
          "type": "string",
          "pattern": "^assets/[A-Za-z0-9][A-Za-z0-9_.-]{0,255}$"
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-fA-F]{64}$"
        },
        "duration_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 3600 },
        "sample_rate": { "type": "integer", "minimum": 8000, "maximum": 384000 },
        "channels": { "type": "integer", "minimum": 1, "maximum": 2 },
        "format": { "type": "string", "maxLength": 20 },
        "weight": { "type": "number", "minimum": 0.1, "maximum": 5 },
        "tags": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "maxLength": 100 }
        },
        "analysis": { "$ref": "#/definitions/AnalysisResult" }
      }
    },
    "AnalysisResult": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bpm": { "$ref": "#/definitions/AnalysisValue" },
        "key": { "$ref": "#/definitions/AnalysisValue" },
        "lufs": { "type": "number", "minimum": -100, "maximum": 20 },
        "energy": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "AnalysisValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "confidence"],
      "properties": {
        "value": { "type": ["number", "string"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_duration_seconds", "clip_duration"],
      "properties": {
        "target_duration_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 3600 },
        "clip_duration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min_seconds", "max_seconds"],
          "properties": {
            "min_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 3600 },
            "max_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 3600 }
          }
        },
        "repetition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_per_clip": { "type": ["integer", "null"], "minimum": 1, "maximum": 100000 },
            "min_gap_clips": { "type": "integer", "minimum": 0, "maximum": 1000 },
            "allow_consecutive": { "type": "boolean" },
            "no_repeat_sections": { "type": "boolean" },
            "repeat_decay": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "crossfade": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "min_seconds": { "type": "number", "minimum": 0, "maximum": 60 },
            "max_seconds": { "type": "number", "minimum": 0, "maximum": 60 },
            "probability": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "silence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "probability": { "type": "number", "minimum": 0, "maximum": 1 },
            "min_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
            "max_seconds": { "type": "number", "minimum": 0, "maximum": 3600 }
          }
        },
        "gain": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "normalize": { "type": "boolean" },
            "target_lufs": { "type": "number", "minimum": -70, "maximum": 0 },
            "max_gain_db": { "type": "number", "minimum": 0, "maximum": 60 },
            "random_variation_db": { "type": "number", "minimum": 0, "maximum": 60 }
          }
        },
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "distribution": { "enum": ["uniform", "weighted", "sequential"] },
            "chaos": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "duration_rule": {
          "enum": ["trim_last", "fade_last", "pad_silence", "fill_random_clip", "extend_last_clip"]
        }
      }
    },
    "RenderSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_duration_seconds", "song_gain_db", "sound_gain_db", "render_gain_db",
        "normalize_output", "master_fade_in_seconds", "master_fade_out_seconds"
      ],
      "properties": {
        "target_duration_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 3600 },
        "song_gain_db": { "type": "number", "minimum": -60, "maximum": 24 },
        "sound_gain_db": { "type": "number", "minimum": -60, "maximum": 24 },
        "render_gain_db": { "type": "number", "minimum": -60, "maximum": 24 },
        "normalize_output": { "type": "boolean" },
        "master_fade_in_seconds": { "type": "number", "minimum": 0, "maximum": 600 },
        "master_fade_out_seconds": { "type": "number", "minimum": 0, "maximum": 600 }
      }
    },
    "Timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["events", "total_duration_seconds"],
      "properties": {
        "total_duration_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "events": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/ClipEvent" },
              { "$ref": "#/definitions/SilenceEvent" }
            ]
          }
        }
      }
    },
    "ClipEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "asset_id", "position_seconds", "source_start_seconds", "source_end_seconds"],
      "properties": {
        "type": { "const": "clip" },
        "asset_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,127}$" },
        "position_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "source_start_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "source_end_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "gain_db": { "type": "number", "minimum": -100, "maximum": 100 },
        "fade_in_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "fade_out_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "locked": { "type": "boolean" }
      }
    },
    "SilenceEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "position_seconds", "duration_seconds"],
      "properties": {
        "type": { "const": "silence" },
        "position_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "duration_seconds": { "type": "number", "minimum": 0, "maximum": 3600 },
        "locked": { "type": "boolean" }
      }
    },
    "ExportSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format", "sample_rate", "bit_depth", "normalize_output",
        "target_output_lufs", "true_peak_limit_dbtp"
      ],
      "properties": {
        "format": { "const": "wav" },
        "sample_rate": { "const": 44100 },
        "bit_depth": { "const": 16 },
        "normalize_output": { "type": "boolean" },
        "target_output_lufs": { "type": "number", "minimum": -70, "maximum": 0 },
        "true_peak_limit_dbtp": { "type": "number", "minimum": -20, "maximum": 0 }
      }
    }
  }
}
